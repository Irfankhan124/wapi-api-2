NODE_ENV=production
PORT=5000

# Use a unique namespace for every separate WAPI installation.
INSTANCE_NAMESPACE=wapi-system-2

# Persistent paths. On Render, attach a persistent disk and use /var/data/wapi-system-2.
DATA_DIR=./data
SESSION_DIR=./sessions

# Comma-separated frontend/admin origins. Use * only for temporary testing.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# none = accept the JWT sent by your WAPI frontend without validating it here.
# api-key = require Authorization: Bearer <API_KEY> or x-api-key.
AUTH_MODE=none
API_KEY=change-this-to-a-long-random-key

# QR and reconnect behavior.
QR_TTL_MS=55000
QR_WAIT_MS=12000
RECONNECT_DELAY_MS=4000
MAX_RECONNECT_DELAY_MS=60000

# Gentle delay between outgoing messages from one WhatsApp account.
SEND_DELAY_MS=750
SYNC_FULL_HISTORY=false

# Optional webhook receiving connection/message events.
WEBHOOK_URL=
WEBHOOK_SECRET=
